# Keep the build context small and, crucially, keep secrets / local state out of the image.

# Secrets and personal/local config (provided in-cluster via Secret + ConfigMap instead).
.env
repos.toml
engineers.toml
scrum.toml

# Local database (a cache of GitHub state; the cluster uses a PVC).
*.db
*.db-shm
*.db-wal

# Python / tooling caches and the local virtualenv (the image builds its own).
__pycache__/
*.py[cod]
.venv/
.mypy_cache/
.ruff_cache/
.pytest_cache/
*.egg-info/
dist/
build/

# VCS and dev tooling.
.git/
.gitignore
tests/
deploy/

# Docs not needed at runtime (README.md is kept — the build references it).
AI_Engineering_Status_Assistant_Prompt.md
