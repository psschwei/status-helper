# Copy to .env and fill in. .env is gitignored.

# GitHub personal access token with read access to the repo below.
# Classic PAT scope: `repo` (or `public_repo` for public repos only).
GITHUB_TOKEN=ghp_your_token_here

# GitHub API base URL.
#   GitHub.com (default):        https://api.github.com
#   GitHub Enterprise Server:    https://your-ghe-host/api/v3
GITHUB_BASE_URL=https://api.github.com

# Set to false only for a GitHub Enterprise Server with a self-signed cert.
GITHUB_SSL_VERIFY=true

# The repositories to watch are configured in repos.toml (copy it from
# repos.toml.example; it's gitignored), not here. Override the path only if you
# keep it elsewhere.
# REPOS_CONFIG_PATH=./repos.toml

# --- LLM (AI summaries) ---
# An OpenAI-compatible endpoint used to generate engineer status summaries. Point this
# at a LiteLLM proxy (recommended, provider-agnostic) or a provider API directly.
#   LiteLLM proxy (default): http://localhost:4000
LLM_BASE_URL=http://localhost:4000
# Optional. Without a key, AI summaries are disabled and the UI shows a "not configured"
# hint instead of the generate button. Some LiteLLM proxy setups don't require one.
# LLM_API_KEY=sk-your_key_here
LLM_MODEL=gpt-4o-mini

# SQLite database file (a cache of GitHub state; safe to delete and re-sync).
DATABASE_URL=sqlite:///./status.db
