# Copy to .env and fill in. .env is gitignored.

# GitHub personal access token with read access to the repo below.
# Classic PAT scope: `repo` (or `public_repo` for public repos only).
GITHUB_TOKEN=ghp_your_token_here

# GitHub API base URL.
#   GitHub.com (default):        https://api.github.com
#   GitHub Enterprise Server:    https://your-ghe-host/api/v3
GITHUB_BASE_URL=https://api.github.com

# Set to false only for a GitHub Enterprise Server with a self-signed cert.
GITHUB_SSL_VERIFY=true

# The repositories to watch are configured in repos.toml (structural config, safe to
# commit), not here. Override the path only if you keep it elsewhere.
# REPOS_CONFIG_PATH=./repos.toml

# SQLite database file (a cache of GitHub state; safe to delete and re-sync).
DATABASE_URL=sqlite:///./status.db
