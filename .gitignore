# Secrets / local config
.env

# Personal list of repositories to watch (copy from repos.toml.example)
repos.toml

# Personal engineer roster for the Engineers view (copy from engineers.toml.example)
engineers.toml

# Personal scrum schedule (optional; copy from scrum.toml.example). Absent = built-in default.
scrum.toml

# Local database (cache of GitHub state — safe to delete and re-sync)
*.db
*.db-shm
*.db-wal

# Real Kubernetes Secret (only the *.example.yaml template is committed)
deploy/k8s/secret.yaml

# Python
__pycache__/
*.py[cod]
.venv/
.mypy_cache/
.ruff_cache/
.pytest_cache/
*.egg-info/
dist/
build/
